{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SPIN Protocol Contract",
  "type": "object",
  "required": ["protocol_id", "protocol_version", "metric_contract"],
  "properties": {
    "protocol_id": { "type": "string" },
    "protocol_version": { "type": "string" },
    "notes": { "type": "string" },
    "metric_contract": {
      "type": "object",
      "required": ["primary", "components"],
      "properties": {
        "primary": { "type": "string" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
